
# ── Database ─────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/financedb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
SPRING_DATA_REDIS_URL=redis://redis:6379
SPRING_DATA_REDIS_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate both values with: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_TOKEN_PEPPER=

# ── Mail (optional — alerts disabled if blank) ───────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
ALERT_EMAIL_FROM=noreply@zorvyn.finance
ALERT_HIGH_VALUE_THRESHOLD=10000

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
